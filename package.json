{
  "name": "tex-for-gmail",
  "version": "1.0.0",
  "private": true,
  "description": "Render LaTeX in Gmail drafts with Firefox and Chrome extensions.",
  "license": "GPL-3.0-only",
  "author": "Tomas Ortega",
  "contributors": [
    "Quoc Ho",
    "Natalie Stewart"
  ],
  "homepage": "https://github.com/TomasOrtega/TeX-for-Gmail#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TomasOrtega/TeX-for-Gmail.git"
  },
  "bugs": {
    "url": "https://github.com/TomasOrtega/TeX-for-Gmail/issues"
  },
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=22.9.0"
  },
  "scripts": {
    "audit": "npm audit --audit-level=high",
    "artifacts:update": "node scripts/update-artifact-lock.js",
    "build": "node scripts/build-extension.js --all",
    "build:chrome": "node scripts/build-extension.js chrome",
    "build:firefox": "node scripts/build-extension.js firefox",
    "build:release": "node scripts/build-release.js",
    "release:artifacts": "node scripts/build-release.js --release",
    "reproduce:firefox": "npm run vendor:mathjax:check && npm run icons:check && npm run verify:release && npm run test:coverage && npm run coverage:check && npm run lint:firefox && npm run build:firefox && npm run verify:zip:firefox",
    "coverage:check": "node scripts/coverage-badge.js --check",
    "coverage:update": "npm run test:coverage && node scripts/coverage-badge.js --write",
    "icons:check": "node scripts/generate-icons.js --check",
    "lint": "npm run lint:firefox",
    "lint:firefox": "node scripts/lint-extension.js",
    "pretest:coverage": "node -e \"require('node:fs').mkdirSync('coverage', { recursive: true })\"",
    "stage": "node scripts/stage-extension.js --all",
    "stage:chrome": "node scripts/stage-extension.js chrome",
    "stage:firefox": "node scripts/stage-extension.js firefox",
    "smoke:browser": "node scripts/smoke-browser.js",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=\"chrome-extension/src/**/*.js\" --test-coverage-lines=100 --test-coverage-branches=60 --test-coverage-functions=65 --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info",
    "validate": "npm run vendor:mathjax:check && npm run icons:check && npm run verify:release && npm run test:coverage && npm run coverage:check && npm run lint && npm run build && npm run verify:zip && npm run smoke:browser && npm run audit",
    "vendor:mathjax": "node scripts/vendor-mathjax.js",
    "vendor:mathjax:check": "node scripts/vendor-mathjax.js --check",
    "verify:artifacts": "node scripts/verify-artifacts.js",
    "verify:release": "node scripts/verify-release.js",
    "verify:zip": "node scripts/verify-zip.js --all",
    "verify:zip:chrome": "node scripts/verify-zip.js chrome",
    "verify:zip:firefox": "node scripts/verify-zip.js firefox"
  },
  "devDependencies": {
    "@mathjax/src": "4.1.2",
    "addons-linter": "10.8.0",
    "adm-zip": "0.6.0"
  }
}
