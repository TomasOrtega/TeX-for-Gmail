{
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "name": "TeX for Gmail (WebAssembly)",
  "short_name": "TeX for Gmail",
  "description": "Render LaTeX as images in Gmail using a local WebAssembly compiler.",
  "version": "1.0.0",
  "author": "TomasOrtega",
  "homepage_url": "https://github.com/TomasOrtega/TeX-for-Gmail",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "contextMenus",
    "offscreen"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "background": {
    "service_worker": "src/chrome-service-worker.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "Insert LaTeX",
    "default_popup": "popup/popup.html"
  },
  "commands": {
    "render-selection": {
      "suggested_key": {
        "default": "Alt+Shift+L"
      },
      "description": "Render the selected LaTeX in Gmail"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*"
      ],
      "run_at": "document_idle",
      "css": [
        "src/contentscr.css"
      ],
      "js": [
        "src/utils.js",
        "src/communicator.js",
        "src/portwrapper.js",
        "src/latex.js",
        "src/contentscr.js"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "default-src 'none'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self'; img-src 'self' data:; style-src 'self'; worker-src 'self'; object-src 'none'"
  },
  "incognito": "not_allowed"
}
